# Copy to .env and fill in. .env is git-ignored.

# Marinesia Premium API key (used only by the ingest worker)
MARINESIA_API_KEY=your_premium_key

# Postgres connection string (Supabase or Neon, with PostGIS enabled).
# Supabase: Project Settings -> Database -> Connection string (URI).
# Use the pooled connection ("Transaction"/pgbouncer) string if deploying serverless.
DATABASE_URL=postgres://user:pass@host:5432/dbname?sslmode=require

# Web server port
PORT=3000

# Ingestion cadence in ms (1 call/min = 60000; rate limit is 5/min)
INGEST_INTERVAL_MS=60000

# Historical backfills per cycle for trail density. 1 (area) + this must stay
# <= 5/min, so keep <= 4. Set 0 to disable backfill.
BACKFILL_PER_CYCLE=3

# A vessel shows on the map if seen in the feed within this many minutes
# (presence by ingestion time, not the age of its last AIS transmission)
LIVE_WINDOW_MIN=15

# Raw positions retention in Postgres (days). Older rows are pruned.
POSITIONS_RETENTION_DAYS=30

# Shared secret protecting the /api/ingest trigger endpoint (optional)
INGEST_TOKEN=change_me

# Set to 1 to run the ingest loop inside the web server process (local dev only).
# In production run `npm run ingest` as a separate always-on worker.
RUN_INGEST_IN_PROCESS=0
